@model Kisi

<div>
    <p>Ad:@Model.Ad</p>
    <p>Soyad:@Model.Soyad</p>
    <p>Yaş:@Model.Yas</p>
</div>

<div>
    @using(Html.BeginForm())
    {
        <b>Ad:</b> @Html.TextBoxFor(x=>x.Ad) <br />
        <b>Soyad:</b> @Html.TextBoxFor(x=>x.Soyad) <br />
        <b>Yaş:</b> @Html.TextBoxFor(x=>x.Yas) <br />
        <hr />
        <input type="submit" value="Gönder" />
    }
</div>