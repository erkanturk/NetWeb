@model Kullanici

@{
    ViewData["Title"] = "Giriş Yap";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-3"> Giriş Yap</h4>
            </div>
            <div class="card-body">
                @if(ViewBag.ErrorMessage!=null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }
                <form asp-action="Login" asp-controller="Account" method="post">
                    <div class="form-group mb-3">
                        <label asp-for="KullaniciAdi" class="form-label"></label>
                        <input asp-for="KullaniciAdi" class="form-control" required placeholder="Kullanıcı Adı"/>
                        <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <input asp-for="Sifre" type="password" class="form-control" required placeholder="Şifre"/>
                        <span asp-validation-for="Sifre" class="text-danger"></span>
                    </div>
                    <input type="submit" class="btn btn-primary w-100" value="Giriş Yap"/>
                </form>
            </div>
        </div>
    </div>
</div>