@model Product
<h1>Details Product</h1>
<table class="table">
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Html.DisplayFor(m => m.ProductId)</td>
            <td>@Html.DisplayFor(m => m.Name)</td>
            <td>@Html.DisplayFor(m => m.Price)</td>
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="ProductId" />
                <input type="submit" value="Delete" class="btn btn-danger"
            </form>
        </tr>
    </tbody>
</table>
<div>
    <a asp-action="Index" class="btn btn-sm btn-info mt-3">Back To Product List</a>
</div>